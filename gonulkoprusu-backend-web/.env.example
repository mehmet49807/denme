APP_NAME="Gönül Köprüsü"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul
APP_URL=http://localhost

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Central MySQL database (credentials supplied later) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gonulkoprusu
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Sanctum (cross-platform token auth) ---
SANCTUM_STATEFUL_DOMAINS=localhost

# --- Firebase (google-services.json supplied later for push notifications) ---
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=

FILESYSTEM_DISK=public
