{
  "name": "gonulkoprusu/backend-web",
  "description": "Laravel API, admin panel, and web frontend boilerplate for Gonul Koprusu.",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
